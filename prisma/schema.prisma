generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  imageUrl  String? 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]
  watchlists Watchlist[]
  sessions Session[]
}

model Watchlist {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  symbols   String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  summaries StockSummary[]
}


model StockSummary {
  id        String   @id @default(cuid())
  symbol    String
  watchlist Watchlist @relation(fields: [watchlistId], references: [id])
  watchlistId String
  date        DateTime
  summary     String    // Swedish AI summary
  createdAt DateTime @default(now())
}

// For Auth.js (NextAuth) - standard models
model Account {
  id        String   @id @default(cuid())
  userId    String
  type      String
  provider  String
  providerAccountId String
  refresh_token String?
  access_token String?
  expires_at Int?
  token_type String?
  scope String?
  id_token String?
  session_state String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id        String   @id @default(cuid())
  sessionToken String @unique
  userId String
  expires DateTime
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerficationToken {
  identifier String
  token String @unique
  expires DateTime

  @@unique([identifier, token])
}